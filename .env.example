# Copy to .env and fill in as you wire real providers.
PORT=3000

# Weather provider: "mock" (default, no key needed) or "openweather"
WEATHER_PROVIDER=mock
OPENWEATHER_API_KEY=

# Market prices provider: "mock" (default) or "agmarknet"
# Agmarknet/eNAM data is available via data.gov.in (register for a free API key)
MARKET_PROVIDER=mock
DATAGOV_API_KEY=

# --- Phase 2+ (not used by the Phase 1 spine yet) ---
# Bhashini (Govt of India ASR/TTS/translation for 22 Indian languages)
BHASHINI_USER_ID=
BHASHINI_API_KEY=
# LLM for the grounded RAG chatbot
LLM_API_KEY=
